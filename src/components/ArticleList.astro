---
import { contentTypeLabel, formatDate, type ArticleSummary } from "@/lib/articles";

interface Props {
  articles: ArticleSummary[];
  pageSize?: number;
}

const { articles, pageSize = 100 } = Astro.props;
const base = import.meta.env.BASE_URL;
const listId = `article-list-${Math.random().toString(36).slice(2)}`;
const articlePayload = articles.map((article, index) => ({
  index,
  title: article.title,
  url: article.url,
  source: article.source,
  published_at: formatDate(article),
  content_type: article.content_type ? contentTypeLabel(article.content_type) : "",
  summary: article.summary || "",
  recommendation_reason: article.recommendation_reason || "",
  tags: article.tags || [],
  dimensions: article.dimensions || {},
}));
---

<section
  class="article-browser"
  data-article-browser
  data-list-id={listId}
  data-page-size={pageSize}
  data-total={articles.length}
>
  <div class="article-list" id={listId}>
    {
      articles.map((article, index) => (
      <article class="article-row" data-article-row data-index={index}>
        <div class="article-row__meta">
          {article.content_type && <span class="content-type">{contentTypeLabel(article.content_type)}</span>}
          <span>{article.source}</span>
          {formatDate(article) && <time datetime={article.published_at || ""}>{formatDate(article)}</time>}
        </div>
        <h2>
          <button class="article-title-button" type="button" data-article-trigger data-index={index}>
            {article.title}
          </button>
        </h2>
        {article.summary && <p>{article.summary}</p>}
        {article.recommendation_reason && <p class="article-row__reason">{article.recommendation_reason}</p>}
        <div class="article-row__footer">
          <div class="tags">
            {(article.tags || []).slice(0, 5).map((tag) => (
              <a href={`${base}tags/${encodeURIComponent(tag)}/`}>{tag}</a>
            ))}
          </div>
          <div class="article-row__actions">
            <button class="source-link article-detail-button" type="button" data-article-trigger data-index={index}>
              详情
            </button>
            <a class="source-link" href={article.url} target="_blank" rel="noreferrer">原文</a>
          </div>
        </div>
      </article>
      ))
    }
  </div>
  <nav class="pagination" aria-label="文章分页" data-pagination hidden></nav>
  <script is:inline type="application/json" data-article-data set:html={JSON.stringify(articlePayload)} />
</section>

<dialog class="article-modal" data-article-modal>
  <div class="article-modal__body">
    <div class="article-modal__top">
      <div class="article-row__meta" data-modal-meta></div>
      <button class="modal-close" type="button" data-modal-close aria-label="关闭">×</button>
    </div>
    <h2 data-modal-title></h2>
    <section class="modal-section" data-modal-summary-section>
      <h3>导读</h3>
      <p data-modal-summary></p>
    </section>
    <section class="modal-section" data-modal-reason-section>
      <h3>推荐理由</h3>
      <p data-modal-reason></p>
    </section>
    <section class="modal-section" data-modal-dimensions-section>
      <h3>评估维度</h3>
      <dl class="dimension-list" data-modal-dimensions></dl>
    </section>
    <div class="tags" data-modal-tags></div>
    <div class="article-modal__actions">
      <a class="button" href="#" target="_blank" rel="noreferrer" data-modal-url>打开原文</a>
      <button class="button button--ghost" type="button" data-modal-close>关闭</button>
    </div>
  </div>
</dialog>

<script>
  type ArticlePayload = {
    index: number;
    title: string;
    url: string;
    source: string;
    published_at: string;
    content_type: string;
    summary: string;
    recommendation_reason: string;
    tags: string[];
    dimensions: Record<string, string>;
  };

  const dimensionLabels: Record<string, string> = {
    depth: "技术深度",
    value: "实践价值",
    novelty: "新颖性",
    readability: "可读性",
  };

  const levelLabels: Record<string, string> = {
    high: "高",
    medium: "中",
    low: "低",
  };

  function escapeHtml(value: string) {
    return value.replace(/[&<>"']/g, (char) => {
      const entities: Record<string, string> = {
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#39;",
      };
      return entities[char] || char;
    });
  }

  function pageFromUrl(totalPages: number) {
    const params = new URLSearchParams(window.location.search);
    const value = Number(params.get("page") || "1");
    if (!Number.isFinite(value)) return 1;
    return Math.min(Math.max(Math.trunc(value), 1), totalPages);
  }

  function syncPageParam(page: number) {
    const url = new URL(window.location.href);
    if (page <= 1) {
      url.searchParams.delete("page");
    } else {
      url.searchParams.set("page", String(page));
    }
    window.history.replaceState({}, "", url);
  }

  function setupPagination(browser: HTMLElement) {
    const rows = Array.from(browser.querySelectorAll<HTMLElement>("[data-article-row]"));
    const pagination = browser.querySelector<HTMLElement>("[data-pagination]");
    const pageSize = Number(browser.dataset.pageSize || "100");
    const totalPages = Math.max(Math.ceil(rows.length / pageSize), 1);
    let currentPage = pageFromUrl(totalPages);

    function render() {
      const start = (currentPage - 1) * pageSize;
      const end = start + pageSize;
      rows.forEach((row, index) => {
        row.hidden = index < start || index >= end;
      });

      if (!pagination || totalPages <= 1) {
        if (pagination) pagination.hidden = true;
        return;
      }

      pagination.hidden = false;
      pagination.innerHTML = `
        <button type="button" data-page-prev ${currentPage === 1 ? "disabled" : ""}>上一页</button>
        <span>第 ${currentPage} / ${totalPages} 页</span>
        <button type="button" data-page-next ${currentPage === totalPages ? "disabled" : ""}>下一页</button>
      `;
    }

    pagination?.addEventListener("click", (event) => {
      const target = event.target as HTMLElement | null;
      if (!target) return;
      if (target.matches("[data-page-prev]")) currentPage = Math.max(currentPage - 1, 1);
      if (target.matches("[data-page-next]")) currentPage = Math.min(currentPage + 1, totalPages);
      syncPageParam(currentPage);
      render();
      browser.scrollIntoView({ block: "start" });
    });

    render();
  }

  function setupModal(browser: HTMLElement) {
    const dataNode = browser.querySelector<HTMLScriptElement>("[data-article-data]");
    const modal = document.querySelector<HTMLDialogElement>("[data-article-modal]");
    if (!dataNode || !modal) return;

    const activeModal = modal;
    const articles = JSON.parse(dataNode.textContent || "[]") as ArticlePayload[];
    const meta = activeModal.querySelector<HTMLElement>("[data-modal-meta]");
    const title = activeModal.querySelector<HTMLElement>("[data-modal-title]");
    const summary = activeModal.querySelector<HTMLElement>("[data-modal-summary]");
    const summarySection = activeModal.querySelector<HTMLElement>("[data-modal-summary-section]");
    const reason = activeModal.querySelector<HTMLElement>("[data-modal-reason]");
    const reasonSection = activeModal.querySelector<HTMLElement>("[data-modal-reason-section]");
    const dimensions = activeModal.querySelector<HTMLElement>("[data-modal-dimensions]");
    const dimensionsSection = activeModal.querySelector<HTMLElement>("[data-modal-dimensions-section]");
    const tags = activeModal.querySelector<HTMLElement>("[data-modal-tags]");
    const url = activeModal.querySelector<HTMLAnchorElement>("[data-modal-url]");

    function openArticle(index: number) {
      const article = articles[index];
      if (!article) return;

      if (meta) {
        meta.innerHTML = [article.content_type, article.source, article.published_at]
          .filter(Boolean)
          .map((item) => `<span>${escapeHtml(item)}</span>`)
          .join("");
      }
      if (title) title.textContent = article.title;
      if (summary) summary.textContent = article.summary;
      if (summarySection) summarySection.hidden = !article.summary;
      if (reason) reason.textContent = article.recommendation_reason;
      if (reasonSection) reasonSection.hidden = !article.recommendation_reason;
      if (dimensions && dimensionsSection) {
        const entries = Object.entries(article.dimensions || {});
        dimensionsSection.hidden = entries.length === 0;
        dimensions.innerHTML = entries
          .map(([key, value]) => `
            <div>
              <dt>${escapeHtml(dimensionLabels[key] || key)}</dt>
              <dd>${escapeHtml(levelLabels[value] || value)}</dd>
            </div>
          `)
          .join("");
      }
      if (tags) {
        tags.innerHTML = article.tags
          .map((tag) => `<a href="${import.meta.env.BASE_URL}tags/${encodeURIComponent(tag)}/">${escapeHtml(tag)}</a>`)
          .join("");
      }
      if (url) url.href = article.url;
      activeModal.showModal();
    }

    browser.addEventListener("click", (event) => {
      const target = (event.target as HTMLElement | null)?.closest<HTMLElement>("[data-article-trigger]");
      if (!target) return;
      openArticle(Number(target.dataset.index));
    });

    activeModal.addEventListener("click", (event) => {
      const target = event.target as HTMLElement | null;
      if (target?.matches("[data-modal-close]")) activeModal.close();
      if (target === activeModal) activeModal.close();
    });
  }

  document.querySelectorAll<HTMLElement>("[data-article-browser]").forEach((browser) => {
    setupPagination(browser);
    setupModal(browser);
  });
</script>
