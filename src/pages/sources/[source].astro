---
import ArticleList from "@/components/ArticleList.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { articlesBySource, getAllArticles, sourcePath, uniqueSources } from "@/lib/articles";

export async function getStaticPaths() {
  const articles = await getAllArticles();
  return uniqueSources(articles).map((source) => ({
    params: { source: sourcePath(source) },
    props: { source, articles: articlesBySource(articles, source) },
  }));
}

const { source, articles } = Astro.props;
---

<BaseLayout title={source}>
  <section class="page-head">
    <div>
      <h1>{source}</h1>
      <p>{articles.length} 篇内容</p>
    </div>
  </section>
  <ArticleList articles={articles} />
</BaseLayout>
