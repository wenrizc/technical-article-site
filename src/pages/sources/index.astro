---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { articlesBySource, getAllArticles, sourcePath, uniqueSources } from "@/lib/articles";

const articles = await getAllArticles();
const sources = uniqueSources(articles);
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="来源">
  <section class="page-head">
    <div>
      <h1>来源</h1>
      <p>按来源浏览收录情况。</p>
    </div>
  </section>
  <div class="source-grid">
    {
      sources.map((source) => (
        <a href={`${base}sources/${sourcePath(source)}/`}>
          <h2>{source}</h2>
          <p>{articlesBySource(articles, source).length} 篇内容</p>
        </a>
      ))
    }
  </div>
</BaseLayout>
