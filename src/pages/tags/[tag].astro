---
import ArticleList from "@/components/ArticleList.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { articlesByTag, getAllArticles, tagPath, uniqueTags } from "@/lib/articles";

export async function getStaticPaths() {
  const articles = await getAllArticles();
  return uniqueTags(articles).map((tag) => ({
    params: { tag: tagPath(tag) },
    props: { tag, articles: articlesByTag(articles, tag) },
  }));
}

const { tag, articles } = Astro.props;
---

<BaseLayout title={tag}>
  <section class="page-head">
    <div>
      <h1>{tag}</h1>
      <p>{articles.length} 篇内容</p>
    </div>
  </section>
  <ArticleList articles={articles} />
</BaseLayout>
