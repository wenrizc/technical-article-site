---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getAllArticles, tagPath, uniqueTags } from "@/lib/articles";

const articles = await getAllArticles();
const tags = uniqueTags(articles);
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="标签">
  <section class="page-head">
    <div>
      <h1>标签</h1>
      <p>按已审核主题浏览已同步内容。</p>
    </div>
  </section>
  <div class="tag-cloud">
    {
      tags.map((tag) => (
        <a href={`${base}tags/${tagPath(tag)}/`}>
          <span>{tag}</span>
          <strong>{articles.filter((article) => article.tags?.includes(tag)).length}</strong>
        </a>
      ))
    }
  </div>
</BaseLayout>
