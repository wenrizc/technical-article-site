---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="搜索" description="搜索已收录的技术与成长内容">
  <section class="page-head">
    <div>
      <h1>搜索</h1>
      <p>按标题、摘要、标签、推荐理由和正文检索内容。</p>
    </div>
  </section>

  <section class="search-panel">
    <label class="search-box">
      <span>关键词</span>
      <input id="search-input" type="search" autocomplete="off" placeholder="输入关键词" />
    </label>
    <div id="search-status" class="search-status">请输入关键词开始搜索。</div>
    <div id="search-results" class="search-results"></div>
  </section>

  <script>
    type PagefindItem = {
      data: () => Promise<{ url: string; excerpt?: string; meta: { title?: string } }>;
    };
    type PagefindModule = {
      search: (term: string) => Promise<{ results: PagefindItem[] }>;
    };

    const input = document.querySelector<HTMLInputElement>("#search-input");
    const status = document.querySelector<HTMLElement>("#search-status");
    const results = document.querySelector<HTMLElement>("#search-results");
    const base = import.meta.env.BASE_URL;

    let pagefindPromise: Promise<PagefindModule> | undefined;
    let timer: number | undefined;
    let activeSearch = 0;

    async function loadPagefind() {
      if (!pagefindPromise) {
        const dynamicImport = new Function("path", "return import(path)") as (
          path: string,
        ) => Promise<PagefindModule>;
        pagefindPromise = dynamicImport(`${base}pagefind/pagefind.js`);
      }
      return pagefindPromise;
    }

    function renderIdle(message: string) {
      if (!status || !results) return;
      status.textContent = message;
      results.innerHTML = "";
    }

    function escapeHtml(value: string) {
      return value.replace(/[&<>"']/g, (char) => {
        const entities: Record<string, string> = {
          "&": "&amp;",
          "<": "&lt;",
          ">": "&gt;",
          '"': "&quot;",
          "'": "&#39;",
        };
        return entities[char] || char;
      });
    }

    async function search(query: string) {
      if (!status || !results) return;
      const searchId = ++activeSearch;
      const term = query.trim();
      if (!term) {
        renderIdle("请输入关键词开始搜索。");
        return;
      }

      status.textContent = "搜索中...";
      results.innerHTML = "";

      try {
        const pf = await loadPagefind();
        const found = await pf.search(term);
        if (searchId !== activeSearch) return;

        const items = await Promise.all(found.results.slice(0, 10).map((item) => item.data()));
        if (searchId !== activeSearch) return;

        status.textContent = found.results.length ? `找到 ${found.results.length} 个结果` : "没有找到结果。";
        results.innerHTML = items
          .map(
            (item: { url: string; excerpt?: string; meta: { title?: string } }) => `
              <article class="search-result">
                <h2><a href="${escapeHtml(item.url)}">${escapeHtml(item.meta.title || item.url)}</a></h2>
                ${item.excerpt ? `<p>${item.excerpt}</p>` : ""}
              </article>
            `,
          )
          .join("");
      } catch (error) {
        if (searchId !== activeSearch) return;
        console.error(error);
        renderIdle("搜索索引暂不可用，请先重新构建静态站。");
      }
    }

    input?.addEventListener("input", (event) => {
      const target = event.currentTarget as HTMLInputElement | null;
      if (!target) return;
      window.clearTimeout(timer);
      timer = window.setTimeout(() => search(target.value), 250);
    });
  </script>
</BaseLayout>
