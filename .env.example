# Upstream FastAPI service, for example:
# TAC_API_BASE_URL=https://example.com
TAC_API_BASE_URL=http://127.0.0.1:1104

# Set to true in CI/deploy if API failures should fail the build instead of using fixtures.
TAC_API_STRICT=false

# GitHub Pages public URL, for sitemap and canonical URLs.
SITE_URL=https://your-name.github.io/technical-article-site/

# Use this when deploying to a GitHub project page.
BASE_PATH=/technical-article-site/
